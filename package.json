{
  "name": "elowen",
  "version": "0.27.77",
  "description": "Elowen is a self-hosted personal AI agent you talk to: chat, act, automate and extend from the CLI, web, Discord, Telegram, Microsoft Teams or WhatsApp.",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/dragocz95/elowen#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dragocz95/elowen.git"
  },
  "bugs": {
    "url": "https://github.com/dragocz95/elowen/issues"
  },
  "keywords": [
    "ai",
    "agent",
    "personal-agent",
    "self-hosted",
    "automation",
    "plugins",
    "llm",
    "cli",
    "tmux"
  ],
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "elowen": "dist/cli/bin.js",
    "elo": "dist/cli/bin.js"
  },
  "files": [
    "dist/",
    "web-dist/",
    "prompts/",
    "plugins/",
    "docs/site/*.md",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "prebuild": "node scripts/dist-integrity.mjs clean && npm run languages-check --silent",
    "build": "tsc -p tsconfig.json && cp src/store/schema.sql dist/store/ && cp -r prompts dist/ && cp -r plugins dist/",
    "postbuild": "node scripts/dist-integrity.mjs chmod-bins && node scripts/dist-integrity.mjs verify",
    "check:dist": "node scripts/dist-integrity.mjs verify",
    "models:refresh": "node scripts/refresh-model-capabilities.mjs",
    "build:web": "node scripts/build-web-bundle.mjs",
    "prepublishOnly": "npm run build && npm run build:web",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cli-tmux": "npm run build --silent && npm run test:cli-tmux:built",
    "test:cli-tmux:built": "node scripts/tests/cli-tmux-built.mjs",
    "test:cli-tmux:goal": "npm run build --silent && node scripts/tests/cli-tmux-goal.mjs",
    "test:cli-tmux:analyze": "node scripts/tests/cli-tmux-analyze.mjs",
    "test:e2e:brain": "npm run build --silent && node scripts/tests/brain-e2e/chat-turn.mjs",
    "test:e2e:telegram": "npm run build --silent && node scripts/tests/telegram-e2e/telegram-roundtrip.mjs",
    "test:e2e:discord": "npm run build --silent && node scripts/tests/discord-e2e/discord-roundtrip.mjs",
    "test:e2e:msteams": "npm run build --silent && node scripts/tests/msteams-e2e/msteams-roundtrip.mjs",
    "test:e2e:cron": "npm run build --silent && node scripts/tests/cron-e2e/run.mjs",
    "test:e2e:api": "npm run build --silent && node scripts/tests/api-e2e/run.mjs",
    "test:e2e:migration": "npm run build --silent && node scripts/tests/migration-e2e/run.mjs",
    "test:e2e:web": "npm run build --silent && npm run build:web && node scripts/tests/web-e2e/run.mjs",
    "test:e2e:whatsapp": "npm run build --silent && node scripts/tests/whatsapp-e2e/whatsapp-roundtrip.mjs",
    "test:e2e:delegate": "npm run build --silent && node scripts/tests/delegate-e2e/run.mjs",
    "test:install": "node scripts/install-smoke/run.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "languages-check": "node --experimental-strip-types --no-warnings scripts/check-languages.mjs",
    "depcruise": "depcruise src web --config .dependency-cruiser.cjs",
    "depgraph": "depcruise src web --config .dependency-cruiser.cjs --output-type dot | dot -T svg -o dependency-graph.svg",
    "deadcode": "knip",
    "check": "npm run lint && npm run deadcode && npm run depcruise && npm run typecheck && npm run languages-check",
    "serve": "node --experimental-strip-types src/daemon/index.ts"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "0.80.10",
    "@earendil-works/pi-coding-agent": "0.80.10",
    "@earendil-works/pi-tui": "0.80.10",
    "@hono/node-server": "^2.0.10",
    "@hono/node-ws": "^1.3.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "baileys": "^7.0.0-rc13",
    "better-sqlite3": "^11.0.0",
    "grammy": "^1.44.0",
    "hono": "^4.6.0",
    "jose": "^5.10.0",
    "qrcode": "^1.5.4",
    "shiki": "^4.3.1",
    "typebox": "^1.1.38",
    "web-push": "^3.6.7",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^16.2.9",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "@types/web-push": "^3.6.4",
    "dependency-cruiser": "^17.4.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.7.0",
    "knip": "^6.17.1",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.62.0",
    "vitest": "^2.1.0"
  }
}
