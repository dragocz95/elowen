    "test:watch": "vitest",
    "serve": "node --experimental-strip-types src/daemon/index.ts"
  },
  "dependencies": { "better-sqlite3": "^11.0.0", "hono": "^4.6.0", "@hono/node-server": "^1.13.0" },
  "devDependencies": { "typescript": "^5.6.0", "vitest": "^2.1.0", "@types/node": "^22.0.0", "@types/better-sqlite3": "^7.6.0" }
}
