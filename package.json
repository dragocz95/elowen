{
  "name": "orca",
  "version": "1.0.1",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "orca": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && cp src/store/schema.sql dist/store/ && cp src/overseer/autopilotPrompt.md dist/overseer/",
    "test": "vitest run",
    "test:watch": "vitest",
    "deadcode": "knip",
    "serve": "node --experimental-strip-types src/daemon/index.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "better-sqlite3": "^11.0.0",
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "knip": "^6.17.1",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
