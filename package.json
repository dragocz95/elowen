{
  "name": "orca",
  "version": "1.0.0",
  "type": "module",
  "engines": { "node": ">=22" },
  "bin": { "orca": "./dist/cli/index.js" },
  "scripts": {
    "build": "tsc -p tsconfig.json && cp src/store/schema.sql dist/store/ && cp src/overseer/autopilotPrompt.md dist/overseer/",
