{
  "name": "elowen",
  "version": "0.26.0",
  "description": "Elowen is a self-hosted personal AI agent you talk to: chat, act, automate and extend from the CLI, web, Discord or WhatsApp.",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/dragocz95/elowen#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dragocz95/elowen.git"
  },
  "bugs": {
    "url": "https://github.com/dragocz95/elowen/issues"
  },
  "keywords": [
    "ai",
    "agent",
    "personal-agent",
    "self-hosted",
    "automation",
    "plugins",
    "llm",
    "cli",
    "tmux"
  ],
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "elowen": "dist/cli/bin.js",
    "elo": "dist/cli/bin.js"
  },
  "files": [
    "dist/",
    "web-dist/",
    "prompts/",
    "plugins/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "prebuild": "node scripts/dist-integrity.mjs clean",
    "build": "tsc -p tsconfig.json && cp src/store/schema.sql dist/store/ && cp -r prompts dist/ && cp -r plugins dist/",
    "postbuild": "node scripts/dist-integrity.mjs verify",
    "check:dist": "node scripts/dist-integrity.mjs verify",
    "build:web": "node scripts/build-web-bundle.mjs",
    "prepublishOnly": "npm run build && npm run build:web",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cli-tmux": "npm run build --silent && npm run test:cli-tmux:built",
    "test:cli-tmux:built": "node scripts/tests/cli-tmux-built.mjs",
    "test:cli-tmux:analyze": "node scripts/tests/cli-tmux-analyze.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "depcruise": "depcruise src web --config .dependency-cruiser.cjs",
    "depgraph": "depcruise src web --config .dependency-cruiser.cjs --output-type dot | dot -T svg -o dependency-graph.svg",
    "deadcode": "knip",
    "check": "npm run lint && npm run deadcode && npm run depcruise && npm run typecheck",
    "serve": "node --experimental-strip-types src/daemon/index.ts"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.80.6",
    "@earendil-works/pi-coding-agent": "^0.80.6",
    "@earendil-works/pi-tui": "^0.80.6",
    "@hono/node-server": "^1.13.0",
    "@hono/node-ws": "^1.3.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "baileys": "^7.0.0-rc13",
    "better-sqlite3": "^11.0.0",
    "hono": "^4.6.0",
    "qrcode": "^1.5.4",
    "typebox": "^1.1.38",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^16.2.9",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "@types/web-push": "^3.6.4",
    "dependency-cruiser": "^17.4.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.7.0",
    "knip": "^6.17.1",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.62.0",
    "vitest": "^2.1.0"
  }
}
