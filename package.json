{
  "name": "orcasynth",
  "version": "1.4.12",
  "description": "ORCA — an autonomous coding-agent orchestrator with an autopilot overseer, daemon API and web UI. Install globally and run `orca`.",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/dragocz1995/orcasynth#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dragocz1995/orcasynth.git"
  },
  "bugs": {
    "url": "https://github.com/dragocz1995/orcasynth/issues"
  },
  "keywords": [
    "ai",
    "agent",
    "orchestrator",
    "autopilot",
    "coding-agent",
    "llm",
    "cli",
    "tmux"
  ],
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "orca": "dist/cli/index.js"
  },
  "files": [
    "dist/",
    "web-dist/",
    "prompts/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && cp src/store/schema.sql dist/store/ && cp -r prompts dist/",
    "build:web": "node scripts/build-web-bundle.mjs",
    "prepublishOnly": "npm run build && npm run build:web",
    "test": "vitest run",
    "test:watch": "vitest",
    "deadcode": "knip",
    "serve": "node --experimental-strip-types src/daemon/index.ts"
  },
  "dependencies": {
    "@clack/prompts": "^1.6.0",
    "@hono/node-server": "^1.13.0",
    "@hono/node-ws": "^1.3.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^11.0.0",
    "hono": "^4.6.0",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "knip": "^6.17.1",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
