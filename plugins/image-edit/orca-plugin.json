{
  "name": "image-edit",
  "version": "0.1.0",
  "apiVersion": "1",
  "description": "Edit an existing image from a text instruction (image-to-image) via the OpenAI Images edits API. The result shows directly in the chat.",
  "entry": "index.mjs",
  "requires": { "config": ["apiKey"] },
  "provides": { "tools": ["edit_image"] },
  "configSchema": [
    { "key": "apiKey", "label": "OpenAI API key", "type": "secret", "required": true, "hint": "platform.openai.com — needs Images API access (gpt-image-1)." },
    { "key": "model", "label": "Model", "type": "string", "hint": "Default: gpt-image-1." }
  ]
}
