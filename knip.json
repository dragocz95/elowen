{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    ".": {
      "project": ["src/**/*.ts", "tests/**/*.ts"]
    },
    "web": {
      "entry": ["app/providers.tsx"]
    }
  },
  "ignoreBinaries": ["tmux"],
  "ignoreIssues": {
    "web/lib/types.ts": ["types"],
    "web/lib/i18n/types.ts": ["types"],
    "web/lib/i18n/dictionaries/index.ts": ["types"]
  }
}
