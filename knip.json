{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    ".": {
      "entry": [
        "plugins/**/index.mjs"
      ],
      "project": [
        "src/**/*.ts",
        "tests/**/*.ts",
        "plugins/**/*.mjs"
      ]
    },
    "web": {
      "entry": [
        "app/providers.tsx"
      ],
      "ignore": [
        "tests/e2e/**",
        "playwright.config.ts"
      ],
      "ignoreDependencies": [
        "@playwright/test"
      ],
      "playwright": false
    }
  },
  "ignoreBinaries": [
    "tmux",
    "which",
    "dot",
    "gh",
    "elowen",
    "ollama",
    "playwright"
  ],
  "ignoreIssues": {
    "web/lib/i18n/types.ts": [
      "types"
    ],
    "web/lib/i18n/dictionaries/index.ts": [
      "types"
    ],
    "src/integrations/cliDetection.ts": [
      "types"
    ],
    "src/plugins/api.ts": [
      "types"
    ],
    "src/brain/transcript.ts": [
      "types"
    ],
    "web/lib/transcript.ts": [
      "exports"
    ]
  },
  "ignore": [
    "web/public/sw.js"
  ]
}
